---
import "@/styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>bvislao — developer</title>
    <meta name="description" content="Full-stack software engineer — 8+ years shipping production software." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="terminal">
      <div id="chrome" class="fixed top-0 left-0 right-0 z-50 flex items-center h-9 px-4 gap-1.5 select-none"
           style="background: #1e1e1e; border-bottom: 1px solid #333;">
        <span class="w-3 h-3 rounded-full" style="background: #ff5f56;"></span>
        <span class="w-3 h-3 rounded-full" style="background: #ffbd2e;"></span>
        <span class="w-3 h-3 rounded-full" style="background: #27c93f;"></span>
        <span class="ml-3 text-xs opacity-40" style="font-family: 'JetBrains Mono', monospace;">bvislao@dev:~/portfolio</span>
        <span class="flex-1"></span>
        <span class="text-[10px] opacity-25" style="font-family: 'JetBrains Mono', monospace;">—zsh— 80×24</span>
      </div>

      <div class="pt-9 min-h-screen" style="background: #0d1117; color: #e6edf3;">
        <div class="mx-auto px-4 sm:px-6 lg:px-8" style="max-width: 832px;">
          <div class="py-2 text-xs opacity-30" style="font-family: 'JetBrains Mono', monospace;">
            Last login: Mon Jun  8 18:46:33 on ttys000
          </div>

          <!-- developer.json -->
          <section id="hero" class="pt-6 pb-8">
            <div class="flex items-baseline flex-wrap gap-x-0">
              <span class="text-sm" style="color: #7ee787; font-family: 'JetBrains Mono', monospace;">bvislao@dev</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">:</span>
              <span class="text-sm" style="color: #79c0ff; font-family: 'JetBrains Mono', monospace;">~</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">$ </span>
              <span id="typed-command" class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;"></span>
              <span id="cursor" class="inline-block w-[7px] h-[15px] ml-[2px]" style="background: #e6edf3;"></span>
            </div>
            <div id="hero-output" class="mt-3 space-y-[3px]">
              <div class="hidden sm:block text-xs" style="color: #8b949e; font-family: 'JetBrains Mono', monospace;"># cat ~/developer.json — profile</div>
              <div style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">
                <span class="opacity-60">{</span>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                <span style="color: #ffa657;">"name"</span><span style="color: #e6edf3;">: </span><span style="color: #7ee787;">"Bryan Vislao"</span>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                <span style="color: #ffa657;">"role"</span><span style="color: #e6edf3;">: </span><span style="color: #7ee787;">"Full-stack Engineer"</span>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                <span style="color: #ffa657;">"location"</span><span style="color: #e6edf3;">: </span><span style="color: #7ee787;">"Lima, Perú"</span>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                <span style="color: #ffa657;">"experience"</span><span style="color: #e6edf3;">: </span><span style="color: #79c0ff;">8+</span><span style="color: #e6edf3;"> </span><span style="color: #7ee787;">"years"</span>
              </div>
              <div style="font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                <span style="color: #ffa657;">"current"</span><span style="color: #e6edf3;">: </span><span style="color: #7ee787;">"Building financial core @ Vivela.lat"</span>
              </div>
              <div style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">
                <span class="opacity-60">}</span>
              </div>
              <div class="pt-4 text-xs leading-relaxed opacity-80" style="color: #8b949e; font-family: 'JetBrains Mono', monospace; max-width: 600px;">
                # Full-stack software engineer with 8+ years shipping production software.
              </div>
              <div class="text-xs leading-relaxed opacity-80" style="color: #8b949e; font-family: 'JetBrains Mono', monospace; max-width: 600px;">
                # Building the product and financial core of Vivela.lat — a real-estate platform.
              </div>
            </div>
          </section>

          <!-- Skills -->
          <section id="skills" class="py-8 border-0 border-t border-solid" style="border-color: #21262d;">
            <div class="flex items-baseline gap-x-0">
              <span class="text-sm" style="color: #7ee787; font-family: 'JetBrains Mono', monospace;">bvislao@dev</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">:</span>
              <span class="text-sm" style="color: #79c0ff; font-family: 'JetBrains Mono', monospace;">~</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">$ </span>
              <span class="text-sm sk-cmd" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">cat ~/skills.md</span>
            </div>
            <div id="skills-output" class="mt-3 space-y-[6px]">
              <div class="hidden sm:block text-xs" style="color: #8b949e; font-family: 'JetBrains Mono', monospace;"># tooling — what I work with every day</div>

              <div class="sk-line" style="font-family: 'JetBrains Mono', monospace;">
                <span style="color: #8b949e;">  &#x26A1; Core</span>
              </div>
              <div class="sk-line text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                Java  Spring  TypeScript  React  Next.js  Node.js  PostgreSQL
              </div>

              <div class="pt-2 sk-line" style="font-family: 'JetBrains Mono', monospace;">
                <span style="color: #8b949e;">  &#x1F9F0; Also work with</span>
              </div>
              <div class="sk-line text-sm" style="color: #8b949e; font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                .NET  C#  Python  NestJS  Express  Vue.js  Redux
              </div>
              <div class="sk-line text-sm" style="color: #8b949e; font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                Tailwind  Sass  MySQL  SQL Server  Oracle
              </div>
              <div class="sk-line text-sm" style="color: #8b949e; font-family: 'JetBrains Mono', monospace; padding-left: 1.5rem;">
                Docker  Git  AWS
              </div>
            </div>
          </section>

          <!-- About -->
          <section id="about-section" class="py-8 border-0 border-t border-solid" style="border-color: #21262d;">
            <div class="flex items-baseline gap-x-0">
              <span class="text-sm" style="color: #7ee787; font-family: 'JetBrains Mono', monospace;">bvislao@dev</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">:</span>
              <span class="text-sm" style="color: #79c0ff; font-family: 'JetBrains Mono', monospace;">~</span>
              <span class="text-sm" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">$ </span>
              <span class="text-sm about-cmd" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace;">cat ~/about.md</span>
            </div>
            <div id="about-output" class="mt-3 space-y-1">
              <div class="hidden sm:block text-xs" style="color: #8b949e; font-family: 'JetBrains Mono', monospace;"># about — bvislao</div>
              <div class="about-line text-sm leading-relaxed" style="color: #e6edf3; font-family: 'JetBrains Mono', monospace; max-width: 620px;">
                Full-stack software engineer with 8+ years shipping production software.
                I currently build the product and financial core of
                <a href="https://vivela.lat" target="_blank" rel="noreferrer noopener" class="hover:underline" style="color: #79c0ff;">Vivela.lat</a>
                — a real-estate platform — focusing on correctness in complex domains
                and maintainable architecture across the whole stack.
              </div>
              <div class="pt-3"></div>
              <div class="about-line" style="font-family: 'JetBrains Mono', monospace;">
                <span style="color: #8b949e;">  &#x1F52D; Building     \u2192</span>
                <span style="color: #e6edf3;"> Vivela.lat (Java/Spring Boot \u00B7 React/TypeScript/Next.js)</span>
              </div>
              <div class="about-line" style="font-family: 'JetBrains Mono', monospace;">
                <span style="color: #8b949e;">  &#x1F9E9; Focused on   \u2192</span>
                <span style="color: #e6edf3;"> domain-driven design, clean architecture, financial accuracy</span>
              </div>
              <div class="about-line" style="font-family: 'JetBrains Mono', monospace;">
                <span style="color: #8b949e;">  &#x1F4EB; Reach me     \u2192</span>
                <a href="mailto:bvislao95@gmail.com" class="hover:underline" style="color: #7ee787;"> bvislao95@gmail.com</a>
              </div>
            </div>
          </section>

        </div>
      </div>
    </div>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: #0d1117;
      }
      #cursor {
        animation: blink 1s step-end infinite;
      }
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
      .sk-line, .about-line { opacity: 0; white-space: pre; }
      @media (prefers-reduced-motion: reduce) {
        .sk-line, .about-line { opacity: 1; }
        #cursor { animation: none; opacity: 0; }
      }
      @media (max-width: 640px) {
        #chrome span:last-child { display: none; }
      }
    </style>

    <script>
    // @ts-nocheck
    const REDIRECT_URL = "https://github.com/bvislao";
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reduce) {
      (async () => {
        const gsapScript = document.createElement("script");
        gsapScript.src = "https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js";
        gsapScript.onload = async () => {
          const stScript = document.createElement("script");
          stScript.src = "https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js";
          await new Promise((r) => { stScript.onload = r; document.head.appendChild(stScript); });
          const gsap = window.gsap;
          const ScrollTrigger = window.ScrollTrigger;
          gsap.registerPlugin(ScrollTrigger);

          // ——— HERO TYPEWRITER ———
          const cmdEl = document.getElementById("typed-command");
          const cursor = document.getElementById("cursor");
          const command = "cat ~/developer.json";
          const heroLines = document.querySelectorAll("#hero-output > div");
          const progress = { val: 0 };

          const tl = gsap.timeline({ delay: 0.6 });
          tl.to(progress, {
            val: command.length,
            duration: 1.6,
            ease: "none",
            onUpdate: () => { cmdEl.textContent = command.slice(0, Math.floor(progress.val)); },
          });
          tl.call(() => { gsap.to(cursor, { opacity: 0, duration: 0.3 }); }, [], "+=0.15");
          tl.from(heroLines, {
            opacity: 0,
            y: 6,
            duration: 0.35,
            stagger: 0.08,
            ease: "power1.out",
          }, "-=0.1");

          // ——— SCROLL REVEALS ———
          const revealOpts = {
            skills: { selector: ".sk-line", from: { opacity: 0, x: -8 }, duration: 0.35, stagger: 0.08, trigger: "#skills" },
            about: { selector: ".about-line", from: { opacity: 0, x: -8 }, duration: 0.35, stagger: 0.1, trigger: "#about-section" },
          };

          Object.values(revealOpts).forEach(({ selector, from, duration, stagger, trigger }) => {
            const els = gsap.utils.toArray(selector);
            if (!els.length) return;
            gsap.from(els, {
              ...from,
              duration,
              ease: "power1.out",
              stagger,
              scrollTrigger: {
                trigger: document.querySelector(trigger),
                start: "top 85%",
                toggleActions: "play none none reverse",
              },
            });
          });
        };
        document.head.appendChild(gsapScript);
      })();
    }

    // ——— OVERSCROLL REDIRECT ———
    let hasRedirected = false;
    let overscrollCount = 0;
    let lastScrollY = window.scrollY;
    let isAtBottom = false;

    window.addEventListener("scroll", () => {
      const scrollHeight = document.documentElement.scrollHeight;
      const clientHeight = document.documentElement.clientHeight;
      const scrollY = window.scrollY;
      const isNearBottom = scrollY + clientHeight >= scrollHeight - 10;

      if (isNearBottom && scrollY > lastScrollY) {
        if (!isAtBottom) { isAtBottom = true; overscrollCount = 0; }
        else {
          overscrollCount++;
          if (overscrollCount >= 2 && !hasRedirected) {
            hasRedirected = true;
            terminalShutdown();
          }
        }
      } else { isAtBottom = false; overscrollCount = 0; }
      lastScrollY = scrollY;
    });

    function terminalShutdown() {
      if (hasRedirected) return;
      const overlay = document.createElement("div");
      overlay.style.cssText = "position:fixed;inset:0;z-index:9999;background:#0d1117;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.75rem;";

      const msgs = [
        { text: "$ shutdown --poweroff", color: "#e6edf3", delay: 0 },
        { text: "saving session...", color: "#8b949e", delay: 0.3 },
        { text: "disconnecting from bvislao@dev", color: "#8b949e", delay: 0.6 },
        { text: "redirecting to github.com/bvislao", color: "#7ee787", delay: 1 },
      ];

      document.body.appendChild(overlay);

      if (typeof window.gsap !== "undefined") {
        const els = msgs.map((m) => {
          const p = document.createElement("p");
          p.textContent = m.text;
          p.style.cssText = `font-family:'JetBrains Mono',monospace;font-size:14px;color:${m.color};opacity:0;`;
          overlay.appendChild(p);
          return p;
        });

        const t = window.gsap.timeline({ delay: 0.2 });
        els.forEach((el, i) => { t.to(el, { opacity: 1, duration: 0.25 }, msgs[i].delay); });
        t.to(overlay, { opacity: 0, duration: 0.35 }, "+=0.2");
        t.call(() => { window.location.href = REDIRECT_URL; });
      } else {
        msgs.forEach((m) => {
          const p = document.createElement("p");
          p.textContent = m.text;
          p.style.cssText = `font-family:'JetBrains Mono',monospace;font-size:14px;color:${m.color};`;
          overlay.appendChild(p);
        });
        setTimeout(() => { window.location.href = REDIRECT_URL; }, 1800);
      }
    }
    </script>
  </body>
</html>
