---
export interface Props {
  name: string;
  role: string;
  tagline: string;
  cta: string;
}
const { name, role, tagline, cta } = Astro.props;
---

<section class="reveal" style="padding: 8rem 0 5rem; min-height: 90vh; display: flex; align-items: center;">
  <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
    <div>
      <p class="code-tag text-xs font-medium mb-4" style="color: rgb(var(--accent));">
        <span style="color: rgb(var(--muted));">$</span> status
        <span class="cursor-blink" style="color: rgb(var(--muted));">_</span>
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-5" style="color: rgb(var(--fg));">
        {role}
      </h1>
      <p class="text-base leading-relaxed mb-8 max-w-md" style="color: rgb(var(--muted));">
        {tagline}
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#work" class="btn btn-primary">
          <span class="code-tag text-xs" style="color: rgb(var(--accent)); opacity: 0.6;">&gt;</span>
          {cta}
        </a>
        <a href="#contact" class="btn btn-outline">
          <span class="code-tag text-xs" style="color: rgb(var(--accent)); opacity: 0.6;">$</span>
          Contacto
        </a>
      </div>
    </div>
    <div class="hidden md:flex items-center justify-center">
      <div class="w-full max-w-sm rounded-xl overflow-hidden pulse-glow" style="background: rgb(var(--card)); border: 1px solid rgb(var(--border));">
        <div class="flex items-center gap-1.5 px-4 py-3" style="border-bottom: 1px solid rgb(var(--border));">
          <span class="w-3 h-3 rounded-full" style="background: #ef4444;"></span>
          <span class="w-3 h-3 rounded-full" style="background: #f59e0b;"></span>
          <span class="w-3 h-3 rounded-full" style="background: #22c55e;"></span>
          <span class="text-xs ml-2 code-tag" style="color: rgb(var(--muted));">terminal — bvislao</span>
        </div>
        <div class="px-4 py-4 code-tag text-xs leading-relaxed" style="color: rgb(var(--muted));">
          <div><span style="color: #22c55e;">bryan@dev</span>:<span style="color: rgb(var(--accent));">~</span>$ <span style="color: rgb(var(--fg));">whoami</span></div>
          <div class="mb-2" style="color: rgb(var(--fg));">Fullstack .NET Developer</div>
          <div><span style="color: #22c55e;">bryan@dev</span>:<span style="color: rgb(var(--accent));">~</span>$ <span style="color: rgb(var(--fg));">cat stack.txt</span></div>
          <div>.NET Core | C# | SQL Server | React</div>
          <div class="mb-2">Oracle | Angular | Azure DevOps</div>
          <div><span style="color: #22c55e;">bryan@dev</span>:<span style="color: rgb(var(--accent));">~</span>$ <span style="color: rgb(var(--fg));">./status.sh</span></div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background: #22c55e;"></span>
            <span style="color: #22c55e;">Disponible para proyectos</span>
          </div>
          <div><span style="color: #22c55e;">bryan@dev</span>:<span style="color: rgb(var(--accent));">~</span>$ <span class="cursor-blink" style="color: rgb(var(--fg));">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>
