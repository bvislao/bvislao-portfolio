---
const links = [
  { href: "#work", label: "Trabajo" },
  { href: "#about", label: "Sobre m\u00ED" },
  { href: "#contact", label: "Contacto" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50" style="background: rgb(var(--bg) / 0.8); backdrop-filter: blur(8px);">
  <div class="container-page h-14 flex items-center justify-between">
    <a href="#" class="text-lg font-bold tracking-tight" style="color: rgb(var(--fg));">
      BV<span style="color: rgb(var(--accent));">.</span>
    </a>
    <div class="flex items-center gap-6 text-sm">
      {links.map(l => (
        <a href={l.href} class="nav-link transition-colors" style="color: rgb(var(--muted));">{l.label}</a>
      ))}
      <button data-theme-toggle class="w-8 h-8 flex items-center justify-center rounded-lg transition-all"
              style="color: rgb(var(--muted)); background: rgb(var(--card)); border: 1px solid rgb(var(--border));"
              aria-label="Toggle theme">
        <svg class="block dark:hidden" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="hidden dark:block" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav-link:hover { color: rgb(var(--fg)) !important; }
</style>
